rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || (
        // Allow updates to followers/following arrays from other users
        isSignedIn() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['followers', 'following'])
      );
    }

    // Posts collection
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn(); // Allow anyone to increment/decrement likes/comments
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && incoming().userId == request.auth.uid;
        allow delete: if isSignedIn() && (existing().userId == request.auth.uid || get(/databases/$(database)/documents/posts/$(postId)).data.userId == request.auth.uid);
      }
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isSignedIn(); // Allow users to send notifications (follow, like, comment)
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
    
    // Reels collection
    match /reels/{reelId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userUid == request.auth.uid;
      allow update: if isSignedIn(); // For likes/comments
      allow delete: if isSignedIn() && existing().userUid == request.auth.uid;
    }
  }
}
